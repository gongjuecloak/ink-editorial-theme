{
  "name": "ink-editorial-theme",
  "version": "1.0.0",
  "description": "Ink Editorial - A minimalist, editorial-style Astro theme for blogs",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./components/*": "./src/components/*",
    "./layouts/*": "./src/layouts/*",
    "./styles/*": "./src/styles/*",
    "./pages/*": "./src/pages/*"
  },
  "files": [
    "src/",
    "index.js",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astro",
    "theme",
    "blog",
    "editorial"
  ],
  "author": "Cloak_Zeng",
  "license": "MIT",
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": ">=4.0.0",
    "sharp": "^0.34.3"
  }
}