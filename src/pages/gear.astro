---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE, AUTHOR } from "../site.config.mjs";
import gearData from "../gear.json";

const totalItems = gearData.reduce((s, g) => s + g.items.length, 0);
const categoryStats = gearData.map(g => ({ name: g.category, count: g.items.length }));

const STATUS_MAP = {
  active: { label: '服役中', color: '#22c55e', bg: 'rgba(34,197,94,0.08)', border: 'rgba(34,197,94,0.2)' },
  retired: { label: '已退役', color: '#94a3b8', bg: 'rgba(148,163,184,0.08)', border: 'rgba(148,163,184,0.2)' },
  idle: { label: '闲置中', color: '#f59e0b', bg: 'rgba(245,158,11,0.08)', border: 'rgba(245,158,11,0.2)' },
};
---

<MainLayout title="我的装备" description="给日子加点料">
  <div class="layout-two-col">
    <div class="layout-main">
      <!-- 页面头 -->
      <div class="page-hero">
        <div class="page-hero-left">
          <div class="page-hero-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
          </div>
          <div class="page-hero-text">
            <h1>我的装备</h1>
            <p>给日子加点料</p>
          </div>
        </div>
        <span class="page-hero-badge">{totalItems} 件好物</span>
      </div>

      <!-- 分类区块 - 列表式 -->
      {gearData.length === 0 ? <p class="empty-state">暂无装备数据，请在 gear.json 中添加。</p> : gearData.map((section) => (
        <div class="gear-section" data-category={section.category}>
          <div class="section-header">
            <h2 class="section-title">{section.category}</h2>
            <span class="section-desc">
              {section.category === '数码装备' ? '提升生产力的硬件设备' :
               section.category === '随身好物' ? '出行与日常随身设备' :
               section.category === '桌面搭子' ? '桌面上的好帮手' : ''}
            </span>
          </div>
          <div class="gear-list">
            {section.items.map((item) => {
              const status = item.status || 'active';
              const statusCfg = STATUS_MAP[status] || STATUS_MAP.active;
              return (
                <div class:list={["gear-item", `gear-item-${status}`]} data-status={status}>
                  <div class="gear-item-img">
                    <img
                      src={item.image}
                      alt={item.name}
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                    />
                    <div class="img-fallback" style="display:none">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                    </div>
                  </div>
                  <div class="gear-item-content">
                    <div class="gear-item-top">
                      <h3 class="gear-item-name" style="word-break:break-word;overflow-wrap:anywhere">
                        {item.link ? (
                          <a href={item.link} target="_blank" rel="noopener noreferrer">{item.name}</a>
                        ) : (
                          item.name
                        )}
                      </h3>
                      <span class="gear-item-spec" style="word-break:break-word;overflow-wrap:anywhere">¥{item.price.replace('¥', '')}</span>
                      <span class="gear-status-tag" style={`color:${statusCfg.color};background:${statusCfg.bg};border-color:${statusCfg.border}`}>
                        {status === 'active' ? '服役中' : status === 'retired' ? '已退役' : '闲置中'}
                      </span>
                    </div>
                    <p class="gear-item-desc">{item.note}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}

      <!-- 底部备注 -->
      <div class="gear-disclaimer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        均为自费购入的真实使用感受，仅供参考
      </div>
    </div>

    <!-- 右侧侧边栏 -->
    <aside class="layout-sidebar">
      <div class="sidebar-card card gear-stat-card">
        <h4 class="sidebar-title">装备概览</h4>
        <div class="gear-stats">
          <div class="gear-stat">
            <span class="gear-stat-num">{totalItems}</span>
            <span class="gear-stat-label">件好物</span>
          </div>
          <div class="gear-stat">
            <span class="gear-stat-num">{gearData.length}</span>
            <span class="gear-stat-label">个分类</span>
          </div>
        </div>
        <div class="gear-status-stats">
          {Object.entries(
            gearData.reduce((acc, g) => {
              g.items.forEach(item => {
                const s = item.status || 'active';
                acc[s] = (acc[s] || 0) + 1;
              });
              return acc;
            }, {})
          ).map(([status, count]) => {
            const cfg = STATUS_MAP[status] || STATUS_MAP.active;
            return (
              <div class="status-stat-item">
                <span class="status-dot" style={`background:${cfg.color}`}></span>
                <span class="status-stat-label">{cfg.label}</span>
                <span class="status-stat-count" style={`color:${cfg.color}`}>{count}</span>
              </div>
            );
          })}
        </div>
      </div>

      <div class="sidebar-card card">
        <h4 class="sidebar-title">分类</h4>
        <div class="category-list">
          {categoryStats.map((cat) => (
            <button class="category-chip" data-cat={cat.name} style={`--cat-color: var(--color-primary)`}>
              <span class="chip-name">{cat.name}</span>
              <span class="chip-count">{cat.count}</span>
            </button>
          ))}
        </div>
      </div>
    </aside>
  </div>
</MainLayout>

<style>
  /* ---- Section ---- */
  .gear-section {
    margin-bottom: var(--gap-xl);
  }
  .section-header {
    margin-bottom: var(--gap-md);
  }
  .section-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 2px;
  }
  .section-desc {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  /* ---- List (Heo-style row layout) ---- */
  .gear-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gear-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }
  .gear-item:hover {
    background: var(--bg-hover);
  }

  /* Retired/Idle dim */
  .gear-item-retired {
    opacity: 0.55;
  }
  .gear-item-retired:hover {
    opacity: 0.75;
  }
  .gear-item-idle {
    opacity: 0.75;
  }
  .gear-item-idle:hover {
    opacity: 0.9;
  }

  /* Thumbnail */
  .gear-item-img {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-hover);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gear-item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .img-fallback {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    opacity: 0.3;
  }

  /* Content */
  .gear-item-content {
    flex: 1;
    min-width: 0;
  }

  .gear-item-top {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .gear-item-name {
    font-size: 0.92rem;
    word-break: break-word;
    overflow-wrap: break-word;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.4;
  }
  .gear-item-name a {
    color: inherit;
    text-decoration: none;
  }
  .gear-item-name a:hover {
    color: var(--color-primary);
  }

  .gear-item-spec {
    font-size: 0.78rem;
    word-break: break-word;
    overflow-wrap: break-word;
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  /* Status tag */
  .gear-status-tag {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    border: 1px solid;
    white-space: nowrap;
    line-height: 1.5;
  }

  .gear-item-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 4px 0 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---- Sidebar ---- */
  .gear-stat-card {
    text-align: center;
  }
  .gear-stats {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xl);
    padding: var(--gap-sm) 0;
  }
  .gear-stat-num {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
  }
  .gear-stat-label {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .gear-status-stats {
    display: flex;
    justify-content: center;
    gap: var(--gap-lg);
    padding-top: var(--gap-sm);
    border-top: 1px solid var(--border-color);
    margin-top: var(--gap-sm);
  }
  .status-stat-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-stat-label {
    color: var(--text-tertiary);
  }
  .status-stat-count {
    font-weight: 700;
  }

  /* ---- Disclaimer ---- */
  .gear-disclaimer {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--gap-sm) var(--gap-md);
    border-radius: var(--radius-md);
    background: var(--bg-hover);
    color: var(--text-tertiary);
    font-size: 0.78rem;
    margin-top: var(--gap-lg);
  }
  .gear-disclaimer svg {
    flex-shrink: 0;
    color: var(--color-primary);
  }

    /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .layout-two-col {
      flex-direction: column;
    }
    .layout-sidebar {
      position: static;
      width: 100%;
    }
    .page-hero {
      padding: var(--gap-md);
      flex-wrap: wrap;
    }
    .page-hero h1 { font-size: 1.3rem; }
    .section-header { margin-bottom: var(--gap-sm); }
    .section-title { font-size: 1rem; }
    .gear-item {
      padding: 10px 12px;
      gap: 10px;
    }
    .gear-item-img {
      width: 48px;
      height: 48px;
    }
    .gear-item-name { font-size: 0.88rem; }
    .gear-item-desc { font-size: 0.78rem; }
    .gear-item-spec { font-size: 0.72rem; }
    .gear-status-tag { font-size: 0.62rem; padding: 2px 6px; }
    .gear-disclaimer { font-size: 0.72rem; }
  }

  @media (max-width: 480px) {
    .layout-main { max-width: 100%; }
    .gear-list { max-width: 100%; }
    .gear-section { max-width: 100%; }
    .page-hero {
      padding: var(--gap-sm);
    }
    .page-hero h1 { font-size: 1.1rem; }
    .page-hero-badge { font-size: 0.7rem; }
    .section-title { font-size: 0.92rem; }
    .section-desc { font-size: 0.72rem; }
    .gear-item {
      padding: 8px 8px;
      gap: 8px;
    }
    .gear-item-img {
      width: 40px;
      height: 40px;
    }
    .gear-item-name { font-size: 0.82rem; }
    .gear-item-desc { font-size: 0.72rem; }
    .gear-item-spec { font-size: 0.66rem; }
    .gear-status-tag { font-size: 0.58rem; padding: 1px 5px; }
    .gear-stats { gap: var(--gap-lg); }
    .gear-stat-num { font-size: 1.3rem; }
    .gear-status-stats { gap: var(--gap-sm); }
    .category-list { gap: 4px; }
    .category-chip { font-size: 0.72rem; padding: 3px 8px; }
    .gear-disclaimer { font-size: 0.68rem; padding: var(--gap-xs) var(--gap-sm); }
  }

</style>