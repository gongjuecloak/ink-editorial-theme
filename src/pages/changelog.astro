    .version-date { font-size: 0.62rem; }
    .change-item { font-size: 0.76rem; padding: 3px 0; gap: 4px; }
    .change-icon { font-size: 0.72rem; width: 18px; }
    .change-text { font-size: 0.76rem; }
  }

</style>