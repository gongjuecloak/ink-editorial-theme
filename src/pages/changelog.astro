---
import MainLayout from "../layouts/MainLayout.astro";
import changelogData from "../changelog.json";

const logs = changelogData;
const latestVersion = logs[0];
const totalChanges = logs.reduce((sum, log) => sum + log.changes.length, 0);

// Classify change type
function classifyChange(text) {
  const t = typeof text === "object" ? (text.desc || text.type || "") : text;
  if (/新增|添加|支持|上线|启用|接入|新文章|新建/.test(t)) return { label: '功能', cls: 'feat' };
  if (/修复|解决|修正|fix|Fix|回退|恢复/.test(t)) return { label: '修复', cls: 'fix' };
  if (/优化|调整|改进|提升|加速|精简|增强/.test(t)) return { label: '优化', cls: 'perf' };
  if (/重设计|美化|样式|风格|动画|视觉|排版|字体|配色|圆角|阴影/.test(t)) return { label: '设计', cls: 'design' };
  if (/重构|迁移|替换|更换|删除|移除|清理|整理/.test(t)) return { label: '重构', cls: 'refactor' };
  if (/文档|说明|注释|README|指南|教程/.test(t)) return { label: '文档', cls: 'docs' };
  if (/部署|构建|发布|CI|CD|打包|版本/.test(t)) return { label: '发布', cls: 'release' };
  if (/安全|权限|加密|认证|鉴权/.test(t)) return { label: '安全', cls: 'security' };
  return { label: '其他', cls: 'other' };
}

// Count changes by type across all logs
const typeCounts = {};
logs.forEach(log => {
  log.changes.forEach(change => {
    const { label } = classifyChange(change.desc || change);
    typeCounts[label] = (typeCounts[label] || 0) + 1;
  });
});
---

<MainLayout title="更新日志" description="站点更新记录">
  <div class="layout-two-col">
    <div class="layout-main">

      <!-- Hero -->
      <div class="cl-hero">
        <div class="cl-hero-left">
          <div class="cl-hero-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div class="cl-hero-text">
            <h1>更新日志</h1>
            <p>每一次改进，都值得被记录</p>
          </div>
        </div>
        <div class="cl-hero-version">
          <span class="cl-hero-ver-label">LATEST</span>
          <span class="cl-hero-ver-num">{latestVersion.version}</span>
        </div>
      </div>

      <!-- Timeline -->
      <div class="cl-timeline">
        {logs.map((log, index) => (
          <div class="cl-item" data-latest={index === 0 ? 'true' : undefined}>
            <div class="cl-rail">
              <div class="cl-node"></div>
              {index < logs.length - 1 && <div class="cl-line"></div>}
            </div>
            <div class="cl-card">
              <div class="cl-card-head">
                <div class="cl-version-row">
                  <span class="cl-version">{log.version}</span>
                  {log.tag && <span class="cl-tag" data-tag={log.tag}>{log.tag}</span>}
                  {log.title && <span class="cl-title-text">{log.title}</span>}
                </div>
                <span class="cl-date">{log.date}</span>
              </div>
              <ul class="cl-changes">
                {log.changes.map((change) => {
                  const desc = typeof change === 'string' ? change : (change.desc || '');
                  const rawType = typeof change === 'object' ? change.type : null;
                  const fallback = classifyChange(desc);
                  const label = rawType || fallback.label;
                  const cls = fallback.cls;
                  return <li class="cl-change">
                    <span class={`cl-type-badge ${cls}`}>{label}</span>
                    <span class="cl-change-text">{desc}</span>
                  </li>;
                })}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <aside class="layout-sidebar">
      <!-- Stats -->
      <div class="sidebar-card card">
        <h4 class="sidebar-title">版本概览</h4>
        <div class="cl-stats">
          <div class="cl-stat-item">
            <span class="cl-stat-num">{logs.length}</span>
            <span class="cl-stat-label">次更新</span>
          </div>
          <div class="cl-stat-item">
            <span class="cl-stat-num">{totalChanges}</span>
            <span class="cl-stat-label">条变更</span>
          </div>
        </div>
        <div class="cl-latest-bar">
          <span class="cl-latest-label">当前版本</span>
          <span class="cl-latest-ver">{latestVersion.version}</span>
        </div>
      </div>

      <!-- Recent versions -->
      <div class="sidebar-card card">
        <h4 class="sidebar-title">近期版本</h4>
        <div class="cl-recent-list">
          {logs.slice(0, 5).map((log) => (
            <div class="cl-recent-item">
              <span class="cl-recent-ver">{log.version}</span>
              <span class="cl-recent-date">{log.date}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Type legend -->
      <div class="sidebar-card card">
        <h4 class="sidebar-title">变更类型</h4>
        <div class="cl-legend">
          {Object.entries(typeCounts).sort((a, b) => b[1] - a[1]).map(([label, count]) => {
            const clsMap = { '功能': 'feat', '修复': 'fix', '优化': 'perf', '设计': 'design', '重构': 'refactor', '文档': 'docs', '发布': 'release', '安全': 'security', '其他': 'other' };
            return <span class={`cl-type-badge ${clsMap[label] || 'other'}`}>{label} {count}</span>;
          })}
        </div>
      </div>
    </aside>
  </div>
</MainLayout>

<style>
  /* ===== Hero ===== */
  .cl-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    padding: 22px 24px;
    margin-bottom: var(--gap-lg);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .cl-hero:hover {
    border-color: var(--color-primary-bg);
    box-shadow: var(--shadow-card-hover);
  }
  .cl-hero-left {
    display: flex;
    align-items: center;
    gap: var(--gap-md);
  }
  .cl-hero-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cl-hero-text h1 {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 2px;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }
  .cl-hero-text p {
    font-size: 0.82rem;
    margin: 0;
    color: var(--text-tertiary);
  }
  .cl-hero-version {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  .cl-hero-ver-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    text-transform: uppercase;
  }
  .cl-hero-ver-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  /* ===== Timeline ===== */
  .cl-timeline { position: relative; }

  .cl-item {
    display: flex;
    gap: 20px;
    position: relative;
  }

  .cl-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 22px;
  }

  .cl-node {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2.5px solid var(--text-tertiary);
    flex-shrink: 0;
    z-index: 1;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .cl-item[data-latest='true'] .cl-node {
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-bg);
  }

  .cl-item:hover .cl-node {
    transform: scale(1.2);
    border-color: var(--color-primary);
  }

  .cl-line {
    width: 2px;
    flex: 1;
    background: var(--border-color);
    border-radius: 1px;
    margin-top: 4px;
  }

  /* ===== Card ===== */
  .cl-card {
    flex: 1;
    padding: 16px 20px;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    margin-bottom: 8px;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .cl-card:hover {
    border-color: color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow: var(--shadow-card-hover);
  }

  .cl-item[data-latest='true'] .cl-card {
    border-color: color-mix(in srgb, var(--color-primary) 18%, transparent);
  }

  /* ===== Card Head ===== */
  .cl-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 8px;
  }

  .cl-version-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .cl-version {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-mono);
  }

  .cl-title-text {
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .cl-date {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ===== Tag ===== */
  .cl-tag {
    font-size: 0.68rem;
    padding: 2px 9px;
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  .cl-tag[data-tag="主题"] { background: rgba(155,89,182,0.1); color: #9B59B6; }
  .cl-tag[data-tag="功能"] { background: rgba(196,82,9,0.1); color: var(--color-primary); }
  .cl-tag[data-tag="优化"] { background: rgba(243,156,18,0.1); color: #F39C12; }
  .cl-tag[data-tag="设计"] { background: rgba(52,152,219,0.1); color: #3498DB; }
  .cl-tag[data-tag="重构"] { background: rgba(231,76,139,0.1); color: #E74C8B; }
  .cl-tag[data-tag="壮举"] { background: rgba(46,139,87,0.1); color: var(--color-accent); }
  .cl-tag[data-tag="修复"] { background: rgba(46,139,87,0.1); color: #2E8B57; }
  .cl-tag[data-tag="发布"] { background: rgba(230,126,34,0.1); color: #E67E22; }

  [data-theme="dark"] .cl-tag[data-tag="主题"] { background: rgba(155,89,182,0.15); color: #B87FD4; }
  [data-theme="dark"] .cl-tag[data-tag="功能"] { background: rgba(224,112,26,0.15); color: #E0701A; }
  [data-theme="dark"] .cl-tag[data-tag="优化"] { background: rgba(243,156,18,0.15); color: #F5B742; }
  [data-theme="dark"] .cl-tag[data-tag="设计"] { background: rgba(52,152,219,0.15); color: #5DADE2; }
  [data-theme="dark"] .cl-tag[data-tag="重构"] { background: rgba(231,76,139,0.15); color: #E86DA0; }
  [data-theme="dark"] .cl-tag[data-tag="壮举"] { background: rgba(46,139,87,0.15); color: #3BAF6F; }
  [data-theme="dark"] .cl-tag[data-tag="修复"] { background: rgba(46,139,87,0.15); color: #3BAF6F; }
  [data-theme="dark"] .cl-tag[data-tag="发布"] { background: rgba(230,126,34,0.15); color: #F0932B; }

  /* ===== Type Badge ===== */
  .cl-type-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.66rem;
    font-weight: 600;
    padding: 1px 8px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    min-width: 36px;
    letter-spacing: 0.02em;
  }

  .cl-type-badge.feat { background: rgba(196,82,9,0.1); color: #C45209; }
  .cl-type-badge.fix { background: rgba(46,139,87,0.1); color: #2E8B57; }
  .cl-type-badge.perf { background: rgba(243,156,18,0.1); color: #F39C12; }
  .cl-type-badge.design { background: rgba(52,152,219,0.1); color: #3498DB; }
  .cl-type-badge.refactor { background: rgba(231,76,139,0.1); color: #E74C8B; }
  .cl-type-badge.docs { background: rgba(155,89,182,0.1); color: #9B59B6; }
  .cl-type-badge.release { background: rgba(230,126,34,0.1); color: #E67E22; }
  .cl-type-badge.security { background: rgba(192,57,43,0.1); color: #C0392B; }
  .cl-type-badge.other { background: rgba(136,136,153,0.1); color: #888899; }

  [data-theme="dark"] .cl-type-badge.feat { background: rgba(224,112,26,0.15); color: #E0701A; }
  [data-theme="dark"] .cl-type-badge.fix { background: rgba(46,139,87,0.15); color: #3BAF6F; }
  [data-theme="dark"] .cl-type-badge.perf { background: rgba(243,156,18,0.15); color: #F5B742; }
  [data-theme="dark"] .cl-type-badge.design { background: rgba(52,152,219,0.15); color: #5DADE2; }
  [data-theme="dark"] .cl-type-badge.refactor { background: rgba(231,76,139,0.15); color: #E86DA0; }
  [data-theme="dark"] .cl-type-badge.docs { background: rgba(155,89,182,0.15); color: #B87FD4; }
  [data-theme="dark"] .cl-type-badge.release { background: rgba(230,126,34,0.15); color: #F0932B; }
  [data-theme="dark"] .cl-type-badge.security { background: rgba(192,57,43,0.15); color: #E74C3C; }
  [data-theme="dark"] .cl-type-badge.other { background: rgba(136,136,153,0.15); color: #9999AA; }

  /* ===== Changes List ===== */
  .cl-changes { list-style: none; padding: 0; margin: 0; }

  .cl-change {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.75;
    padding: 2px 0;
  }

  .cl-change-text { flex: 1; }

  /* ===== Sidebar Stats ===== */
  .cl-stats {
    display: flex;
    justify-content: center;
    gap: var(--gap-xl);
    padding: var(--gap-sm) 0 var(--gap-md);
  }

  .cl-stat-item { text-align: center; }

  .cl-stat-num {
    display: block;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
    font-family: var(--font-mono);
  }

  .cl-stat-label {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cl-latest-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--gap-sm) var(--gap-md);
    background: var(--color-primary-bg);
    border-radius: var(--radius-sm);
  }

  .cl-latest-label {
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  .cl-latest-ver {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-mono);
  }

  /* ===== Recent Versions ===== */
  .cl-recent-list { display: flex; flex-direction: column; gap: 2px; }

  .cl-recent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    transition: background var(--transition-fast);
  }

  .cl-recent-item:hover { background: var(--bg-hover); }

  .cl-recent-ver {
    font-weight: 600;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .cl-recent-date {
    color: var(--text-tertiary);
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }

  /* ===== Legend ===== */
  .cl-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 4px 0;
  }

  /* ===== Responsive ===== */
    @media (max-width: 640px) {
    .changelog-page { padding: var(--gap-sm) var(--gap-md); }
    .changelog-hero { padding: var(--gap-lg) var(--gap-md); margin-bottom: var(--gap-md); }
    .changelog-hero h1 { font-size: 1.3rem; }
    .changelog-hero-stats { gap: var(--gap-md); }
    .changelog-hero-stat .stat-num { font-size: 1.2rem; }
    .changelog-hero-stat .stat-label { font-size: 0.65rem; }
    .changelog-layout { grid-template-columns: 1fr; gap: var(--gap-md); }
    .changelog-sidebar { position: static; }
    .timeline { padding-left: var(--gap-md); }
    .timeline::before { left: 8px; }
    .timeline-dot { left: -28px; width: 10px; height: 10px; }
    .version-entry { padding: var(--gap-sm) 0 var(--gap-md); }
    .version-header { flex-wrap: wrap; gap: 6px; }
    .version-tag { font-size: 0.85rem; }
    .latest-badge { font-size: 0.6rem; padding: 2px 6px; }
    .version-date { font-size: 0.68rem; }
    .change-item { font-size: 0.82rem; padding: 4px 0; }
    .change-icon { font-size: 0.78rem; width: 20px; }
