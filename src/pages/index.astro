  .tier-tag:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .tier-tag::after {
    content: attr(data-count);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--text-tertiary);
    position: absolute;
    top: -2px;
    right: -10px;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .tier-tag:hover::after {
    opacity: 1;
  }

  .tier-core {
    font-weight: 600;
    color: var(--text-primary);
  }

  .tier-mid {
    font-size: 0.78rem;
    opacity: 0.7;
    font-weight: 500;
  }

  /* ===== Rare Tags Toggle ===== */
  .rare-tags-wrap {
    margin-top: var(--gap-sm);
    border-top: 1px solid var(--border-color);
    padding-top: var(--gap-sm);
  }

  .rare-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
