    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--border-color-strong, rgba(0,0,0,0.14));
    text-transform: lowercase;
  }

  /* ===== 最新文章 — Ink Editorial Magazine Style ===== */
  .latest-section { margin-bottom: var(--gap-2xl, 4rem); }

  .latest-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border-color, rgba(0,0,0,0.08));
  }

