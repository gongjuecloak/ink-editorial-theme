---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, AUTHOR } from '../site.config.mjs';
import { sortPosts } from '../utils';

let allPosts = [];
try { allPosts = await getCollection('blog'); } catch(e) { allPosts = []; }
const posts = sortPosts(allPosts);
const totalPosts = posts.length;

// 系列文集：统计所有 series，去重后按文章数排序
const seriesMap = {};
posts.forEach(post => {
  if (post.data.series) {
    if (!seriesMap[post.data.series]) {
      seriesMap[post.data.series] = { name: post.data.series, count: 0, slugs: [] };
    }
    seriesMap[post.data.series].count++;
    seriesMap[post.data.series].slugs.push(post.id);
  }
});
const seriesList = Object.values(seriesMap).sort((a, b) => b.count - a.count);

// 碎片流：改为「最新文章」（前 8 篇，按日期倒序）
const fragmentPosts = posts.slice(0, 10);

// NOW 条数据（读取 now.json）
const fs = await import('fs/promises');
const nowRaw = await fs.readFile('src/now.json', 'utf-8');
const nowData = JSON.parse(nowRaw);
const nowLogs = nowData.slice(0, 5).map(item => ({
  text: item.text.length > 30 ? item.text.slice(0, 30) + '...' : item.text,
}));

// 生成 JS 数组字符串（避免模板语法问题）
const nowLogsJS = JSON.stringify(nowLogs);

// 标签频率统计：按出现次数分级
const tagFreqMap = new Map();
posts.forEach(p => {
  (p.data.tags || []).forEach(t => {
    tagFreqMap.set(t, (tagFreqMap.get(t) || 0) + 1);
  });
});
const allTagsSorted = [...tagFreqMap.entries()].sort((a, b) => b[1] - a[1]);
const coreTags = allTagsSorted.filter(([_, c]) => c >= 3);    // 高频
const minorTags = allTagsSorted.filter(([_, c]) => c === 2);  // 中频
const rareTags = allTagsSorted.filter(([_, c]) => c === 1);  // 低频
const totalTags = tagFreqMap.size;
const maxFreq = allTagsSorted[0]?.[1] || 1;

const now = {
  logsJS: nowLogsJS,
  totalTags,
};
---

<MainLayout title={SITE.title} description={AUTHOR.motto}>
  <!-- ===== TERMINAL HERO ===== -->
  <div class="terminal-hero">
    <div class="terminal-frame">
      <div class="terminal-titlebar">
        <span class="terminal-dot dot-r"></span>
        <span class="terminal-dot dot-y"></span>
        <span class="terminal-dot dot-g"></span>
        <span class="terminal-title">cloak@blog ~ </span>
      </div>
      <div class="terminal-body">
        <div class="terminal-line" data-index="0"><span class="terminal-text">> CloakBlog v{SITE.startYear}.0 — initializing...</span></div>
        <div class="terminal-line" data-index="1"><span class="terminal-text">> Loaded {totalPosts} articles, {new Set(posts.map(p => p.data.category)).size} categories</span></div>
        <div class="terminal-line" data-index="2"><span class="terminal-text">> {totalTags} tags indexed</span></div>
        <div class="terminal-line" data-index="3"><span class="terminal-text">> Now: 在云端俯瞰图景，在图景中寻找云的方向。</span></div>
        <div class="terminal-line" data-index="4"><span class="terminal-text">> Ready.</span><span class="terminal-cursor">_</span></div>
      </div>
    </div>
  </div>

  <!-- ===== NOW BAR ===== -->
  <div class="now-bar">
    <div class="now-inner">
      <span class="now-label">NOW</span>
      <span class="now-sep">▸</span>
      <span class="now-doing" id="now-doing">加载中...</span>
      
    </div>
  </div>

  <script define:vars={{ logsJSON: now.logsJS }}>
    (function() {
      const logs = JSON.parse(logsJSON);
      let idx = 0;
      const el = document.getElementById('now-doing');
      function rotate() {
        const log = logs[idx];
        if (log && log.text) {
          el.textContent = log.text;
        }
        idx = (idx + 1) % logs.length;
      }
      rotate();
      setInterval(rotate, 3000);
    })();
  </script>

  <!-- ===== MAIN GRID: content + sidebar ===== -->
  <div class="home-grid">
    <!-- 左侧主内容 -->
    <div class="home-main">

      <!-- ===== 最新文章 ===== -->
      <section class="section latest-section">
        <h2 class="section-title">最新<span class="section-sub">latest</span></h2>

        <div class="latest-list">
          {fragmentPosts.map((post, i) => {
            const date = new Date(post.data.pubDate);
            const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
            const shortDate = date.toLocaleDateString('zh-CN', { month: 'numeric', day: 'numeric' });
            return (
              <a href={`/blog/${post.id}`} class="latest-item" data-index={i}>
                <span class="latest-accent"></span>
                
                <div class="latest-body">
                  <div class="latest-head">
                    <h3 class="latest-title">{post.data.title}</h3>
                    <p class="latest-desc">{post.data.description || ''}</p>
                  </div>
                  
                  <div class="latest-meta">
                    {post.data.category && (
                      <span class="latest-cat" data-cat={post.data.category}>{post.data.category}</span>
                    )}
                    <time class="latest-date">{dateStr}</time>
                    <span class="latest-comments" data-url={`/blog/${post.id}`}></span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- ===== 系列文集 ===== -->
      <section class="section">
        <h2 class="section-title">系列<span class="section-sub">series</span></h2>
        <div class="series-grid">
          {seriesList.map((series) => (
            <a href={`/series/${encodeURIComponent(series.name)}`} class="series-card">
              <div class="series-name">{series.name}</div>
              <div class="series-meta">
                <span class="series-count">{series.count} 篇</span>
                <span class="series-arrow">▸</span>
              </div>
            </a>
          ))}
        </div>
      </section>

    </div>

    <!-- 右侧侧边栏 -->
    <aside class="home-sidebar">
      <div class="sidebar-card status-card">
        <h4 class="sidebar-title">状态<span class="section-sub">status</span></h4>
        <div class="status-grid">
          <div class="status-item">
            <span class="status-num">{totalPosts}</span>
            <span class="status-label">文章</span>
          </div>
          <div class="status-item">
            <span class="status-num">{new Set(posts.map(p => p.data.category)).size}</span>
            <span class="status-label">分类</span>
          </div>
          <div class="status-item">
            <span class="status-num">{totalTags}</span>
            <span class="status-label">标签</span>
          </div>
        </div>
      </div>

      <div class="sidebar-card">
        <h4 class="sidebar-title">分类<span class="section-sub">categories</span></h4>
        <div class="category-list">
          {[...new Set(posts.map(p => p.data.category))].filter(Boolean).map((name) => (
            <a href={`/archive?category=${encodeURIComponent(name)}`} class="category-chip">
              <span class="chip-name">{name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="sidebar-card tag-card">
        <h4 class="sidebar-title">标签<span class="section-sub">tags</span></h4>
        <div class="tag-tier-cloud">
          <!-- 高频标签（≥3次）大字号权重云 -->
          {coreTags.map(([tag, count]) => {
            const weight = Math.max(0.75, count / maxFreq);
            const fontSize = `${0.72 + weight * 0.4}rem`;
            const opacity = `${0.55 + weight * 0.45}`;
            return (
              <a href={`/archive?tag=${encodeURIComponent(tag)}`} class:list={['tier-tag', 'tier-core']} style={`font-size:${fontSize};opacity:${opacity}`} data-count={count}>
                {tag}
              </a>
            );
          })}
          <!-- 中频标签（2次） -->
          {minorTags.map(([tag, count]) => (
            <a href={`/archive?tag=${encodeURIComponent(tag)}`} class:list={['tier-tag', 'tier-mid']} data-count={count}>
              {tag}
            </a>
          ))}
        </div>
        <!-- 低频标签（1次）可展开 -->
        {rareTags.length > 0 && (
          <div class="rare-tags-wrap" id="rare-tags-wrap">
            <button class="rare-toggle" id="rare-toggle" aria-expanded="false">
              <span class="rare-toggle-text">+ {rareTags.length} 更多标签</span>
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="rare-tags-hidden" id="rare-tags-hidden">
              {rareTags.map(([tag, count]) => (
                <a href={`/archive?tag=${encodeURIComponent(tag)}`} class:list={['tier-tag', 'tier-rare']} data-count={1}>
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </aside>
  </div>
</MainLayout>

<style>
  /* ===== HOME GRID: CSS Grid, no flex crush ===== */
  .home-grid {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: var(--gap-md, 1rem) var(--gap-lg, 2rem) 0;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--gap-lg, 2rem);
    align-items: start;
  }

  .home-main {
    min-width: 0;
    overflow: hidden;
  }

  /* ===== Tag Tier Cloud ===== */
