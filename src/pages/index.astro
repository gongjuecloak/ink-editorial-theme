    color: var(--color-primary);
    opacity: 0.8;
  }

  .home-sidebar {
    width: 280px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--nav-height, 52px) + var(--gap-md, 1rem));
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm, 0.5rem);
  }

  /* ===== TERMINAL HERO ===== */
  .terminal-hero {
    max-width: var(--max-width, 1200px);
    margin: var(--gap-lg, 2rem) auto 0;
    padding: 0 var(--gap-lg, 2rem);
  }

  .terminal-frame {
    border: 1px solid var(--border-color-strong, rgba(0,0,0,0.14));
