    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-tertiary, #999);
    letter-spacing: 0.02em;
    margin-left: auto;
  }

.latest-comments {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-tertiary);
  opacity: 0.7;
}
.latest-comments svg {
  width: 11px;
  height: 11px;
}


  .latest-featured .latest-date {
    font-size: 0.78rem;
    color: var(--text-secondary, #666);
  }

  /* ===== Series Grid ===== */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-md, 1rem);
  }

  .series-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    text-decoration: none;
    border: 1px solid var(--border-color, rgba(0,0,0,0.08));
