  .rare-tags-hidden {
    display: none;
    flex-wrap: wrap;
    gap: 5px 7px;
    padding-top: var(--gap-sm);
  }

  .rare-tags-hidden.show {
    display: flex;
  }

  .tier-rare {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-tertiary);
    opacity: 0.5;
