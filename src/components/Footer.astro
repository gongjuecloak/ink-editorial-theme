---
import { SITE, AUTHOR, FOOTER, SOCIAL_LINKS } from "../site.config.mjs";
import changelogData from "../changelog.json";
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-brand">{SITE.title}</span>
      <span class="footer-divider">·</span>
      <span class="footer-copyright">{FOOTER.copyright}</span>
    </div>
    <div class="footer-right">
      {SOCIAL_LINKS.map((link) => (
        <a href={link.url} class="social-link" target="_blank" rel="noopener" aria-label={link.name}>
          {link.name === 'GitHub' && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          )}
          {link.name === 'B站' && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906L17.813 4.653zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773H5.333zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/></svg>
          )}
          {link.name === '邮箱' && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          )}
        </a>
      ))}
      <span class="footer-divider">·</span>
      <a href="/changelog" class="footer-link">主题日志</a>
      <span class="footer-divider">·</span>
      <span class="footer-powered">Theme by <a href="/theme">Ink Editorial</a> {changelogData[0].version}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-body);
    border-top: 1px solid var(--border-color);
    padding: var(--gap-md) 0;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gap-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .footer-brand {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .footer-divider {
    color: var(--border-color-strong);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--gap-md);
  }

  .social-link {
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-primary);
  }

  .footer-link {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-powered {
    color: var(--text-tertiary);
    font-size: 0.78rem;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--gap-md);
      text-align: center;
      padding: 0 var(--gap-md);
    }
    .footer-left {
      flex-direction: column;
      gap: 2px;
    }
    .footer-right {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--gap-sm);
    }
    .social-link {
      padding: 4px;
    }
  }
</style>
