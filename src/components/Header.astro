---
import { SITE, NAV_LINKS } from "../site.config.mjs";
const pathname = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="返回首页">
      <span class="logo-icon">
        <img src="/logo.svg" alt="云图札记" width="28" height="28" />
      </span>
      <span class="logo-text">{SITE.title}</span>
    </a>

    <nav class="nav" aria-label="主导航">
      {NAV_LINKS.map((link) => (
        <a href={link.path} class:list={["nav-link", { active: pathname === link.path || (link.path !== '/' && pathname.startsWith(link.path)) }]}>
          {link.name}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button class="search-btn" id="search-btn" aria-label="搜索文章">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div class="mobile-nav" id="mobile-nav">
    {NAV_LINKS.map((link) => (
      <a href={link.path} class:list={["mobile-nav-link", { active: pathname === link.path || (link.path !== '/' && pathname.startsWith(link.path)) }]}>
        {link.name}
      </a>
    ))}
  </div>
</header>

<div class="header-spacer"></div>

<script is:inline>
  (function() {
    var themeBtn = document.getElementById('theme-toggle');
    themeBtn && themeBtn.addEventListener('click', function() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });

    var searchBtn = document.getElementById('search-btn');
    searchBtn && searchBtn.addEventListener('click', function() {
      window.location.href = "/search";
    });

    var mobileBtn = document.getElementById('mobile-menu-btn');
    var mobileNav = document.getElementById('mobile-nav');
    mobileBtn && mobileBtn.addEventListener('click', function() {
      if (mobileNav) mobileNav.classList.toggle('open');
    });
  })();
</script>

<style>
  .header {
    position: fixed;
    top:0; left:0; right:0;
    height: var(--nav-height);
    background: var(--bg-nav);
    border-bottom: 2px solid var(--color-primary);
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin:0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding:0 var(--gap-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.01em;
    font-family: var(--font-mono);
  }

  .logo-icon {
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm);
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(196, 82, 9, 0.3);
  }

  .logo-text {
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1px;
    height: 100%;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0 12px;
    height: 100%;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    font-weight: 700;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
  }

  .search-btn, .theme-toggle {
    width: 34px;
    height: 34px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    font-family: inherit;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .search-btn:hover, .theme-toggle:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .mobile-menu-btn {
    display: none;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: transparent;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    font-family: inherit;
  }

  .mobile-menu-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .mobile-nav { display: none; }

  .icon-moon { display: none; }
  [data-theme="dark"] .icon-sun { display: none; }
  [data-theme="dark"] .icon-moon { display: block; }

  .header-spacer { height: var(--nav-height); }

  @media (max-width: 768px) {
    .header-inner { padding:0 var(--gap-md); }
    .nav { display: none; }
    .mobile-menu-btn { display: flex; }

    .mobile-nav {
      display: none;
      position: fixed;
      top: var(--nav-height);
      left:0; right:0;
      background: var(--bg-card);
      border-bottom: 2px solid var(--color-primary);
      padding: var(--gap-sm) 0;
      z-index: 99;
      flex-direction: column;
    }

    .mobile-nav.open { display: flex; }

    .mobile-nav-link {
      padding: 10px var(--gap-lg);
      font-size: 0.85rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-family: var(--font-mono);
      border-left: 3px solid transparent;
      transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
    }

    .mobile-nav-link:hover, .mobile-nav-link.active {
      color: var(--color-primary);
      border-left-color: var(--color-primary);
      background: var(--color-primary-bg);
    }
  }

  @media (max-width: 480px) {
    :root { --nav-height: 44px; }
    .header-inner { padding: 0 var(--gap-sm); }
    .logo { gap: 6px; font-size: 0.9rem; }
    .logo-icon { width: 26px; height: 26px; }
    .logo-icon svg { width: 16px; height: 16px; }
    .search-btn, .theme-toggle { width: 30px; height: 30px; }
    .search-btn svg, .theme-toggle svg { width: 15px; height: 15px; }
    .mobile-menu-btn { width: 30px; height: 30px; }
    .mobile-menu-btn svg { width: 17px; height: 17px; }
    .mobile-nav-link { padding: 8px var(--gap-md); font-size: 0.8rem; }
  }
</style>
