---
export interface Props {
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info' | 'purple';
  size?: 'sm' | 'md';
}

const { variant = 'default', size = 'md' } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`, `badge--${size}`]}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid transparent;
  }

  .badge--sm {
    padding: 2px 6px;
    font-size: 0.625rem;
    border-radius: var(--radius-sm);
  }

  .badge--md {
    padding: 3px 8px;
    font-size: 0.6875rem;
    border-radius: var(--radius-md);
  }

  /* Default — rust orange */
  .badge--default {
    background-color: var(--color-primary-bg);
    color: var(--color-primary);
    border-color: var(--color-primary-bg);
  }

  /* Success — green */
  .badge--success {
    background-color: rgba(46, 139, 87, 0.08);
    color: #2E8B57;
    border-color: rgba(46, 139, 87, 0.12);
  }

  /* Warning — amber */
  .badge--warning {
    background-color: rgba(180, 130, 0, 0.08);
    color: #A48000;
    border-color: rgba(180, 130, 0, 0.12);
  }

  /* Error — red */
  .badge--error {
    background-color: rgba(180, 30, 30, 0.08);
    color: #B41E1E;
    border-color: rgba(180, 30, 30, 0.12);
  }

  /* Info — blue-grey */
  .badge--info {
    background-color: rgba(60, 100, 140, 0.08);
    color: #3C648C;
    border-color: rgba(60, 100, 140, 0.12);
  }

  /* Purple — purple-grey */
  .badge--purple {
    background-color: rgba(90, 60, 140, 0.08);
    color: #5A3C8C;
    border-color: rgba(90, 60, 140, 0.12);
  }

  /* Dark mode overrides */
  [data-theme="dark"] .badge--default {
    background-color: var(--color-primary-bg);
    color: var(--color-primary-light);
    border-color: var(--color-primary-bg);
  }
  [data-theme="dark"] .badge--success {
    background-color: rgba(59, 175, 111, 0.08);
    color: #3BAF6F;
    border-color: rgba(59, 175, 111, 0.12);
  }
  [data-theme="dark"] .badge--warning {
    background-color: rgba(200, 160, 0, 0.08);
    color: #C8A000;
    border-color: rgba(200, 160, 0, 0.12);
  }
  [data-theme="dark"] .badge--error {
    background-color: rgba(220, 60, 60, 0.08);
    color: #DC3C3C;
    border-color: rgba(220, 60, 60, 0.12);
  }
  [data-theme="dark"] .badge--info {
    background-color: rgba(80, 140, 180, 0.08);
    color: #508CB4;
    border-color: rgba(80, 140, 180, 0.12);
  }
  [data-theme="dark"] .badge--purple {
    background-color: rgba(120, 90, 180, 0.08);
    color: #785AB4;
    border-color: rgba(120, 90, 180, 0.12);
  }
</style>