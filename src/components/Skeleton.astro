---
export interface Props {
  width?: string;
  height?: string;
  rounded?: 'none' | 'sm' | 'md' | 'full';
}

const {
  width = '100%',
  height = '1em',
  rounded = 'md',
} = Astro.props;

const radiusMap: Record<string, string> = {
  none: '0',
  sm:   'var(--radius-sm)',
  md:   'var(--radius-md)',
  full: 'var(--radius-xl)',
};
---

<div
  class:list={['skeleton', `skeleton--${rounded}`]}
  style={`width: ${width}; height: ${height}; border-radius: ${radiusMap[rounded]};`}
  aria-hidden="true"
></div>

<style>
  .skeleton {
    display: block;
    background: linear-gradient(
      90deg,
      var(--bg-hover) 0%,
      var(--border-color) 50%,
      var(--bg-hover) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.4s linear infinite;
    font-family: var(--font-mono);
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Dark mode: adjust shimmer colors */
  [data-theme="dark"] .skeleton {
    background: linear-gradient(
      90deg,
      var(--bg-card-hover) 0%,
      var(--border-color-strong) 50%,
      var(--bg-card-hover) 100%
    );
    background-size: 200% 100%;
  }
</style>